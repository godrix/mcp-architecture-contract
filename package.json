    "hexagonal",
    "arc.yaml"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "deepmerge": "^4.3.1",
    "fast-glob": "^3.3.3",
    "handlebars": "^4.7.8",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
