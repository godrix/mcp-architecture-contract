{
  "name": "arc-mcp",
  "version": "1.0.0",
  "description": "Architecture Contract MCP — agnostic architecture discovery, scaffolding and validation via arc.yaml",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "arc-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "presets",
    "templates"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-assets.mjs",
    "test": "vitest run",
